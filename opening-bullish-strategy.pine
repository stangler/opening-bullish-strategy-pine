//@version=6
strategy("ズレ手法", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=10)

// 入力
slTicks        = input.int(10, "SL (ナンピン2からTick数)", minval=1)
tpTicks        = input.int(5,  "TP (平均取得価格 + Tick数)", minval=1)
nappin1Ticks   = input.int(10, "ナンピン1 下落Tick（初回から）", minval=1)
nappin2Ticks   = input.int(10, "ナンピン2 追加下落Tick（ナンピン1から）", minval=1)
bearCount      = input.int(4,  "陰線本数", minval=2, maxval=6)
alertPreSignal = input.bool(true, "事前アラート（N-1本陰線）")

// バックテスト期間
startDate = input.time(timestamp("2026-04-01 00:00"), "開始日")
endDate   = input.time(timestamp("2026-04-24 23:59"), "終了日")
inRange   = time >= startDate and time <= endDate

// 取引時間帯
tradeStartHour = input.int(9,  "取引開始 時", minval=0, maxval=23)
tradeStartMin  = input.int(0,  "取引開始 分", minval=0, maxval=59)
tradeEndHour   = input.int(15, "取引終了 時", minval=0, maxval=23)
tradeEndMin    = input.int(30, "取引終了 分", minval=0, maxval=59)

timeOk = (hour > tradeStartHour or (hour == tradeStartHour and minute >= tradeStartMin)) and
         (hour < tradeEndHour   or (hour == tradeEndHour   and minute <= tradeEndMin))

// 陰線判定
bearish(i) => close[i] < open[i]

// N本連続陰線シグナル
var signal = false
if bearCount == 2
    signal := bearish(0) and bearish(1)
else if bearCount == 3
    signal := bearish(0) and bearish(1) and bearish(2)
else if bearCount == 4
    signal := bearish(0) and bearish(1) and bearish(2) and bearish(3)
else if bearCount == 5
    signal := bearish(0) and bearish(1) and bearish(2) and bearish(3) and bearish(4)
else if bearCount == 6
    signal := bearish(0) and bearish(1) and bearish(2) and bearish(3) and bearish(4) and bearish(5)

// N-1本陰線（事前シグナル）
var preSignal = false
if bearCount == 2
    preSignal := bearish(0)
else if bearCount == 3
    preSignal := bearish(0) and bearish(1)
else if bearCount == 4
    preSignal := bearish(0) and bearish(1) and bearish(2)
else if bearCount == 5
    preSignal := bearish(0) and bearish(1) and bearish(2) and bearish(3)
else if bearCount == 6
    preSignal := bearish(0) and bearish(1) and bearish(2) and bearish(3) and bearish(4)

// 大引け判定
eodClose = hour == 15 and minute >= 25

tickSize = syminfo.mintick

// ナンピン管理
var float entryPrice  = na
var bool  nappin1Done = false
var bool  nappin2Done = false

// リセット（ポジなし）
if strategy.position_size == 0
    entryPrice  := na
    nappin1Done := false
    nappin2Done := false

// 初回エントリー価格キャプチャ（初回のみ）
if strategy.position_size > 0 and na(entryPrice)
    entryPrice := strategy.position_avg_price

// TP/SL 動的計算
float avgPrice = strategy.position_avg_price
float tpPrice  = strategy.position_size > 0 ? avgPrice + tpTicks * tickSize : na
float slPrice  = na(entryPrice) ? na : entryPrice - (nappin1Ticks + nappin2Ticks + slTicks) * tickSize

// TP/SL 判定（毎バー）
if strategy.position_size > 0 and not eodClose
    if not na(tpPrice) and high >= tpPrice
        strategy.close_all(comment="TP")
    else if not na(slPrice) and low <= slPrice
        strategy.close_all(comment="SL")

// 大引け強制決済
if eodClose and strategy.position_size > 0
    strategy.close_all(comment="大引け")

// 初回エントリー
if signal and strategy.position_size == 0 and inRange and timeOk and not eodClose
    strategy.entry("Long", strategy.long)

// ナンピン1（初回から nappin1Ticks 下）
if strategy.position_size > 0 and not nappin1Done and not na(entryPrice) and
   low <= entryPrice - nappin1Ticks * tickSize and inRange and timeOk and not eodClose
    strategy.entry("Nappin1", strategy.long)
    nappin1Done := true

// ナンピン2（初回から nappin1Ticks + nappin2Ticks 下）
if strategy.position_size > 0 and nappin1Done and not nappin2Done and not na(entryPrice) and
   low <= entryPrice - (nappin1Ticks + nappin2Ticks) * tickSize and inRange and timeOk and not eodClose
    strategy.entry("Nappin2", strategy.long)
    nappin2Done := true

// 事前アラート
if preSignal and not signal and inRange and timeOk and not eodClose and alertPreSignal
    alert("ズレ手法: " + syminfo.ticker + " 陰線N-1本確定。次の陰線でエントリー候補。", alert.freq_once_per_bar)

// 可視化
plotshape(signal and inRange and timeOk and not eodClose, "シグナル", shape.triangleup, location.belowbar, color.green, size=size.small)
plotshape(preSignal and not signal and inRange and timeOk and not eodClose, "事前シグナル", shape.triangleup, location.belowbar, color.orange, size=size.tiny)
plot(strategy.position_size > 0 and not na(tpPrice) ? tpPrice : na, "TP Line", color.lime, style=plot.style_linebr)
plot(strategy.position_size > 0 and not na(slPrice) ? slPrice : na, "SL Line", color.red,  style=plot.style_linebr)

bgcolor(not inRange ? color.new(color.gray, 90) : na)

// === レポートテーブル ===
showTable = input.bool(true, "レポートテーブル表示", group="レポート設定")

var table reportTable = table.new(
     position.top_right, columns = 2, rows = 15,
     bgcolor = color.new(color.white, 80), border_width = 1,
     frame_color = color.gray, border_color = color.gray)

if showTable and (barstate.islastconfirmedhistory or barstate.islast)
    float max_dd_amount = strategy.max_drawdown
    float max_dd_pct    = strategy.initial_capital > 0 ? (strategy.max_drawdown / strategy.initial_capital) * 100 : na

    table.cell(reportTable, 0, 0, "項目", text_color = color.white, bgcolor = color.new(#1e88e5, 0), text_size = size.normal)
    table.cell(reportTable, 1, 0, "値",   text_color = color.white, bgcolor = color.new(#1e88e5, 0), text_size = size.normal)

    int r = 1

    table.cell(reportTable, 0, r, "Net Profit", text_color = color.white)
    table.cell(reportTable, 1, r, str.tostring(strategy.netprofit, "#,###.##"),
               text_color = strategy.netprofit >= 0 ? color.green : color.red)
    r += 1

    table.cell(reportTable, 0, r, "Gross Profit", text_color = color.white)
    table.cell(reportTable, 1, r, str.tostring(strategy.grossprofit, "#,###.##"), text_color = color.white)
    r += 1

    table.cell(reportTable, 0, r, "Gross Loss", text_color = color.white)
    table.cell(reportTable, 1, r, str.tostring(strategy.grossloss, "#,###.##"), text_color = color.white)
    r += 1

    float pf = strategy.grossloss != 0 ? strategy.grossprofit / math.abs(strategy.grossloss) : na
    table.cell(reportTable, 0, r, "Profit Factor", text_color = color.white)
    table.cell(reportTable, 1, r, na(pf) ? "—" : str.tostring(pf, "#.##"),
               text_color = pf >= 1.5 ? color.green : (pf >= 1.0 ? color.orange : color.red))
    r += 1

    float win_rate = strategy.closedtrades > 0 ? (strategy.wintrades / strategy.closedtrades) * 100 : 0
    table.cell(reportTable, 0, r, "Win Rate %", text_color = color.white)
    table.cell(reportTable, 1, r, str.tostring(win_rate, "#.##") + "%",
               text_color = win_rate >= 50 ? color.green : color.red)
    r += 1

    table.cell(reportTable, 0, r, "Total Trades", text_color = color.white)
    table.cell(reportTable, 1, r, str.tostring(strategy.closedtrades), text_color = color.white)
    r += 1

    table.cell(reportTable, 0, r, "Win Trades", text_color = color.white)
    table.cell(reportTable, 1, r, str.tostring(strategy.wintrades), text_color = color.white)
    r += 1

    table.cell(reportTable, 0, r, "Loss Trades", text_color = color.white)
    table.cell(reportTable, 1, r, str.tostring(strategy.losstrades), text_color = color.white)
    r += 1

    table.cell(reportTable, 0, r, "Max Drawdown %", text_color = color.white)
    table.cell(reportTable, 1, r, na(max_dd_pct) ? "—" : str.tostring(max_dd_pct, "#.##") + "%", text_color = color.white)
    r += 1

    table.cell(reportTable, 0, r, "Max Drawdown (金額)", text_color = color.white)
    table.cell(reportTable, 1, r, str.tostring(max_dd_amount, "#,###.##"), text_color = color.white)
    r += 1

    float dd_profit_ratio = strategy.netprofit != 0 ? (max_dd_amount / strategy.netprofit) * 100 : na
    table.cell(reportTable, 0, r, "DD/Profit Ratio", text_color = color.white)
    table.cell(reportTable, 1, r, na(dd_profit_ratio) ? "—" : str.tostring(dd_profit_ratio, "#.##") + "%",
               text_color = na(dd_profit_ratio) ? color.white :
                            strategy.netprofit <= 0 ? color.red :
                            dd_profit_ratio > 50 ? color.red :
                            dd_profit_ratio > 30 ? color.orange : color.green)