//@version=6
strategy("寄付09:00入 09:05出 統計", overlay=true, process_orders_on_close=true)

// --- 期間入力 ---
start_date = input.time(timestamp("2026-04-01 00:00"), "開始日")
end_date   = input.time(timestamp("2026-04-26 23:59"), "終了日") // 本日まで

// --- 判定ロジック ---
in_range = time >= start_date and time <= end_date
is_first = timeframe.change("D") and in_range

// 09:00始値エントリー（前日最終足で予約 → 当日始値約定）
if timeframe.change("D")[1] and in_range
    strategy.entry("Entry", strategy.long)

// 09:00足確定（09:05）で即エグジット
if is_first
    strategy.close("Entry")

// --- 結果表示（陽線判定） ---
is_bull = close > open
if is_first
    label.new(bar_index, high, is_bull ? "陽線\n(始値<終値)" : "陰線\n(始値>終値)", 
         color=is_bull ? color.green : color.red, textcolor=color.white)